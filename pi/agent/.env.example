# Extension API keys for ~/.pi/agent
# Copy to .env and fill in values. Never commit .env.

# Exa web search (extensions/exa-search)
EXA_API_KEY=

# Discord upload (extensions/discord-upload)
# Option A: webhook — simplest, posts to one channel
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# @mention on every post (Discord → Settings → Advanced → Developer Mode → right-click your name → Copy User ID)
DISCORD_MENTION_USER_ID=YOUR_DISCORD_USER_ID

# Option B: bot — post via bot token (webhook takes priority if both are set)
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=
