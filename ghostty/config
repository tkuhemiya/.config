theme = Dracula
window-colorspace = display-p3
background = "000000"
foreground = "FAE3C6"
selection-background = "F564A9"
selection-foreground = "FAE3C6"
selection-clear-on-copy = false

#font-family = JetBrains Mono
#font-family = Osaka-Mono
#font-family = JetBrains Mono Light
font-family = Moxy
font-size = 16
font-thicken = true
adjust-cursor-thickness = 175%
#adjust-cell-width = -4%
adjust-cell-height = 17%

macos-titlebar-style = hidden
window-decoration = none
macos-non-native-fullscreen = true

title = " "

background-opacity = 0.92
background-opacity-cells = false
background-blur = 40
unfocused-split-opacity = 0.9
#custom-shader = ./ghostty-shaders/slash.glsl

quick-terminal-size = 50%,50%
quick-terminal-position = center
quick-terminal-animation-duration = 0.1


macos-option-as-alt = true
#keybind = ctrl+h=goto_split:left
#keybind = ctrl+j=goto_split:bottom
#keybind = ctrl+k=goto_split:top
#keybind = ctrl+l=goto_split:right
#
#keybind = ctrl+a>h=new_split:left
#keybind = ctrl+a>j=new_split:down
#keybind = ctrl+a>k=new_split:up
#keybind = ctrl+a>l=new_split:right

keybind = super+r=reload_config

#keybind = global:cmd+enter=toggle_quick_terminal
keybind = super+ctrl+f=toggle_fullscreen
