// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "server_url": "https://zed.dev",
  "proxy": "",
  "use_system_window_tabs": false,
  "status_bar": {
    "cursor_position_button": false,
    "active_language_button": true
  },
  "project_panel": {
    "button": true
  },
  "prettier": {
    "allowed": true
  },
  "completions": {
    "lsp_fetch_timeout_ms": 0
  },
  "document_folding_ranges": "on",
  "semantic_tokens": "combined",
  "colorize_brackets": true,
  "code_lens": "on",
  "soft_wrap": "bounded",
  "vim": {
    "show_edit_predictions_in_normal_mode": true,
    "use_system_clipboard": "never"
  },
  "toolbar": {
    "code_actions": true,
    "agent_review": true,
    "quick_actions": true,
    "breadcrumbs": true
  },
  "minimap": {
    "thumb": "hover",
    "display_in": "active_editor",
    "show": "never"
  },
  "gutter": {
    "line_numbers": true
  },
  "hover_popover_hiding_delay": 100,
  "hover_popover_delay": 100,
  "which_key": {
    "enabled": true
  },
  "current_line_highlight": "all",
  "hide_mouse": "never",
  "cursor_shape": "bar",
  "multi_cursor_modifier": "cmd_or_ctrl",
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 400.0,
  "restore_on_startup": "none",
  "disable_ai": true,
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed"
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^cd\\s+interfaces(\\s|$)"
            },
            {
              "pattern": "^go\\s+run(\\s|$)"
            }
          ]
        }
      }
    },
    "default_model": {
      "effort": "high",
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true
    },
    "favorite_models": [
      {
        "provider": "opencode",
        "model": "free/big-pickle",
        "enable_thinking": false
      },
      {
        "provider": "opencode",
        "model": "go/deepseek-v4-flash",
        "enable_thinking": true,
        "effort": "high"
      },
      {
        "provider": "opencode",
        "model": "go/deepseek-v4-pro",
        "enable_thinking": true,
        "effort": "max"
      }
    ],
    "model_parameters": []
  },
	 "file_scan_exclusions": [
    "**/.git",
    "**/.venv",
    "**/dist",
    "**/node_modules",
    "**/target",
    "**/.wrangler"
  ],
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "model": "opencode-go/deepseek-v4-flash"
      },
      "type": "registry"
    },
    "your_agent": {
      "type": "custom",
      "command": "/opt/homebrew/bin/pi",
    },
  },
  "language_models": {
    "opencode": {
      "show_free_models": true,
      "show_zen_models": false,
    },
  },
  "ui_font_family": "Moxy",
  "buffer_font_family": "Moxy",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Colored Zed Icons Theme Dark",
  },
  "terminal": {
    "button": true,
    "font_size": 10.0,
    "font_family": "Moxy",
  },
  "cli_default_open_behavior": "existing_window",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "restore_unsaved_buffers": false,
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 13.0,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Rose Pine",
  },
  "languages": {
    "Python": {
      "language_servers": [
        "ty",
        "!basedpyright",
        "ruff",
      ],
      "format_on_save": "on",
    },
  },
}
